{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{
        "expr": "forge_http_requests_total",
        "legendFormat": "requests"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 100000 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "Total 5xx Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{
        "expr": "forge_http_errors_total",
        "legendFormat": "errors"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "title": "Avg Latency (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "expr": "forge_http_latency_avg_ms",
        "legendFormat": "latency"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "ms"
        }
      }
    },
    {
      "id": 4,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{
        "expr": "forge_uptime_seconds",
        "legendFormat": "uptime"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 5,
      "title": "Request Rate (per 15s scrape)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "forge_http_requests_total",
        "legendFormat": "total requests"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineWidth": 2
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 6,
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{
        "expr": "forge_http_errors_total",
        "legendFormat": "5xx errors"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 7,
      "title": "Latency Trend (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [{
        "expr": "forge_http_latency_avg_ms",
        "legendFormat": "avg latency"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Requests by Path",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [{
        "expr": "forge_http_requests_by_path",
        "format": "table",
        "legendFormat": "{{ path }}"
      }]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["forge", "platform"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Forge Platform Health",
  "uid": "forge-platform-health"
}
