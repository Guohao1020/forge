# Forge AI Worker Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# === Temporal ===
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TASK_QUEUE=ai-worker

# === LLM API Keys (at least one required) ===
# Routing priority: DashScope → Anthropic → OpenAI → DeepSeek
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=sk-your-dashscope-key
DEEPSEEK_API_KEY=

# === Forge Core API ===
FORGE_API_URL=http://localhost:8080
# Get token by logging in: curl -X POST localhost:8080/api/auth/login -d '{"username":"admin","password":"admin123"}'
# Or use dev-start.sh which auto-refreshes this token
FORGE_API_TOKEN=

# === Redis (for streaming code output) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=forge_redis_2026
